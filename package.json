    "btch-downloader": "^6.0.27",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "express": "^4.22.2",
    "express-session": "^1.19.0",
    "firebase": "^12.12.0",
    "firebase-admin": "^13.8.0",
    "form-data": "^4.0.5",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
